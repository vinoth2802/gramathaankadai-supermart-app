  @@map("sale_returns")
}

model SaleReturnItem {
  id         Int        @id @default(autoincrement())
  returnId   Int        @map("return_id")
  productId  Int?       @map("product_id")
  name       String
  qty        Decimal    @db.Decimal(12, 3)
  rate       Decimal    @db.Decimal(12, 2)
  unit       String?
  gstRate    Decimal    @default(0) @map("gst_rate") @db.Decimal(5, 2)
  gstAmount  Decimal    @default(0) @map("gst_amount") @db.Decimal(12, 2)
  amount     Decimal    @db.Decimal(12, 2)
  createdAt  DateTime   @default(now()) @map("created_at")
  saleReturn SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@map("sale_return_items")
}

model PurchaseReturn {
  id               Int                  @id @default(autoincrement())
  debitNoteNo      String               @unique @map("debit_note_no")
  date             DateTime             @default(now()) @db.Date
  partyId          Int?                 @map("party_id")
  partyName        String               @default("Walk-in Supplier") @map("party_name")
  referenceInvoice String?              @map("reference_invoice")
  type             String               @default("Debit Note")
  subtotal         Decimal              @default(0) @db.Decimal(12, 2)
  gst              Decimal              @default(0) @db.Decimal(12, 2)
  grandTotal       Decimal              @default(0) @map("grand_total") @db.Decimal(12, 2)
  paymentMode      String?              @default("Cash") @map("payment_mode")
  totalPaid        Decimal              @default(0) @map("total_paid") @db.Decimal(12, 2)
