generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AppPermission {
  id              BigInt              @id @default(autoincrement())
  module          String              @db.VarChar(50)
  action          String              @db.VarChar(50)
  description     String?             @db.Text
  rolePermissions AppRolePermission[]

  @@unique([module, action], map: "module")
  @@map("app_permissions")
}

model AppRolePermission {
  roleId       BigInt        @map("role_id")
  permissionId BigInt        @map("permission_id")
  role         AppRole       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "app_role_permissions_ibfk_1")
  permission   AppPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "app_role_permissions_ibfk_2")

  @@id([roleId, permissionId])
  @@index([permissionId], map: "permission_id")
  @@map("app_role_permissions")
}

model AppRole {
  id              BigInt              @id @default(autoincrement())
  tenantId        BigInt              @map("tenant_id")
  name            String              @db.VarChar(50)
  description     String?             @db.Text
  color           String?             @db.VarChar(40)
  isSystem        Boolean             @default(false) @map("is_system")
  createdAt       DateTime            @default(now()) @map("created_at") @db.DateTime(0)
  rolePermissions AppRolePermission[]
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "app_roles_ibfk_1")
  users           AppUser[]

  @@unique([tenantId, name], map: "tenant_id")
  @@map("app_roles")
}

model AppUser {
  id                                  BigInt                   @id @default(autoincrement())
  tenantId                            BigInt                   @map("tenant_id")
  name                                String?                  @db.VarChar(100)
  email                               String                   @db.VarChar(150)
  phone                               String?                  @db.VarChar(20)
  passwordHash                        String?                  @map("password_hash") @db.Text
  roleId                              BigInt?                  @map("role_id")
  employeeId                          BigInt?                  @map("employee_id")
  avatarUrl                           String?                  @map("avatar_url") @db.Text
  isActive                            Boolean                  @default(true) @map("is_active")
  emailVerifiedAt                     DateTime?                @map("email_verified_at") @db.DateTime(0)
  mustChangePassword                  Boolean                  @default(false) @map("must_change_password")
  passwordResetToken                  String?                  @map("password_reset_token") @db.Text
  passwordResetExpires                DateTime?                @map("password_reset_expires") @db.DateTime(0)
  failedLoginCount                    Int                      @default(0) @map("failed_login_count")
  lockedUntil                         DateTime?                @map("locked_until") @db.DateTime(0)
  lastLogin                           DateTime?                @map("last_login") @db.DateTime(0)
  createdAt                           DateTime                 @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt                           DateTime                 @default(now()) @map("updated_at") @db.DateTime(0)
  tenant                              Tenant                   @relation("app_users_tenant_idTotenants", fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "app_users_ibfk_1")
  role                                AppRole?                 @relation(fields: [roleId], references: [id], onUpdate: NoAction, map: "app_users_ibfk_2")
  employee                            Employee?                @relation(fields: [employeeId], references: [id], onUpdate: NoAction, map: "app_users_ibfk_3")
  auditLog                            AuditLog[]
  importJobs                          ImportJob[]
  leaveRequests                       LeaveRequest[]
  notificationPreferences             NotificationPreference[]
  notifications                       Notification[]
  posSessions                         PosSession[]
  purchases                           Purchase[]
  recycleBin                          RecycleBin[]
  salesSalesCashierUserIdToappUsers   Sale[]                   @relation("sales_cashier_user_idToapp_users")
  salesSalesCreatedByUserIdToappUsers Sale[]                   @relation("sales_created_by_user_idToapp_users")
  stockAdjustments                    StockAdjustment[]
  supportTickets                      SupportTicket[]
  tenantsTenantsOwnerUserIdToappUsers Tenant[]                 @relation("tenants_owner_user_idToapp_users")
  userSessions                        UserSession[]

  @@unique([tenantId, email], map: "tenant_id")
  @@index([employeeId], map: "employee_id")
  @@index([roleId], map: "role_id")
  @@map("app_users")
}

model AssetDepreciationSchedule {
  id           BigInt     @id @default(autoincrement())
  tenantId     BigInt     @map("tenant_id")
  fixedAssetId BigInt     @map("fixed_asset_id")
  period       DateTime?  @db.Date
  openingValue Decimal?   @map("opening_value") @db.Decimal(14, 2)
  depreciation Decimal?   @db.Decimal(14, 2)
  closingValue Decimal?   @map("closing_value") @db.Decimal(14, 2)
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "asset_depreciation_schedule_ibfk_1")
  fixedAsset   FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "asset_depreciation_schedule_ibfk_2")

  @@index([fixedAssetId], map: "fixed_asset_id")
  @@index([tenantId], map: "tenant_id")
  @@map("asset_depreciation_schedule")
}

model AttendanceRecord {
  id            BigInt          @id @default(autoincrement())
  tenantId      BigInt          @map("tenant_id")
  employeeId    BigInt          @map("employee_id")
  locationId    BigInt?         @map("location_id")
  shiftId       BigInt?         @map("shift_id")
  date          DateTime?       @db.Date
  status        String?         @db.VarChar(20)
  checkIn       DateTime?       @map("check_in") @db.Time(0)
  checkOut      DateTime?       @map("check_out") @db.Time(0)
  workedHours   Decimal?        @map("worked_hours") @db.Decimal(5, 2)
  overtimeHours Decimal?        @map("overtime_hours") @db.Decimal(5, 2)
  note          String?         @db.Text
  createdAt     DateTime        @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt     DateTime        @default(now()) @map("updated_at") @db.DateTime(0)
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "attendance_records_ibfk_1")
  employee      Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "attendance_records_ibfk_2")
  location      TenantLocation? @relation(fields: [locationId], references: [id], onUpdate: NoAction, map: "attendance_records_ibfk_3")
  shift         Shift?          @relation(fields: [shiftId], references: [id], onUpdate: NoAction, map: "attendance_records_ibfk_4")

  @@unique([tenantId, employeeId, date], map: "tenant_id")
  @@index([employeeId], map: "employee_id")
  @@index([tenantId, date], map: "idx_attendance_tenant_date")
  @@index([locationId], map: "location_id")
  @@index([shiftId], map: "shift_id")
  @@map("attendance_records")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  tenantId   BigInt?  @map("tenant_id")
  logTime    DateTime @default(now()) @map("log_time") @db.DateTime(0)
  userId     BigInt?  @map("user_id")
  userName   String?  @map("user_name") @db.VarChar(100)
  action     String?  @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   BigInt?  @map("entity_id")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  details    Json?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "audit_log_ibfk_1")
  user       AppUser? @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "audit_log_ibfk_2")

  @@index([tenantId, logTime], map: "idx_audit_log_tenant_time")
  @@index([userId], map: "user_id")
  @@map("audit_log")
}

model BackupJob {
  id         BigInt   @id @default(autoincrement())
  tenantId   BigInt   @map("tenant_id")
  mode       String?  @db.VarChar(20)
  storageUrl String?  @map("storage_url") @db.Text
  status     String?  @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(0)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "backup_jobs_ibfk_1")

  @@index([tenantId], map: "tenant_id")
  @@map("backup_jobs")
}

model BankAccount {
  id                BigInt              @id @default(autoincrement())
  tenantId          BigInt              @map("tenant_id")
  bankName          String?             @map("bank_name") @db.VarChar(255)
  accountNo         String?             @map("account_no") @db.VarChar(50)
  ifsc              String?             @db.VarChar(20)
  type              String?             @default("Current") @db.VarChar(20)
  balance           Decimal?            @default(0.00) @db.Decimal(14, 2)
  createdAt         DateTime            @default(now()) @map("created_at") @db.DateTime(0)
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bank_accounts_ibfk_1")
  bankTransactions  BankTransaction[]
  cheques           Cheque[]
  paymentInHistory  PaymentInHistory[]
  paymentOutHistory PaymentOutHistory[]

  @@index([tenantId], map: "tenant_id")
  @@map("bank_accounts")
}

model BankTransaction {
  id            BigInt      @id @default(autoincrement())
  tenantId      BigInt      @map("tenant_id")
  bankAccountId BigInt      @map("bank_account_id")
  date          DateTime?   @db.Date
  direction     String?     @db.VarChar(5)
  amount        Decimal?    @db.Decimal(12, 2)
  refTable      String?     @map("ref_table") @db.VarChar(40)
  refId         BigInt?     @map("ref_id")
  description   String?     @db.Text
  balance       Decimal?    @db.Decimal(14, 2)
  createdAt     DateTime    @default(now()) @map("created_at") @db.DateTime(0)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bank_transactions_ibfk_1")
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bank_transactions_ibfk_2")

  @@index([bankAccountId], map: "bank_account_id")
  @@index([tenantId], map: "tenant_id")
  @@map("bank_transactions")
}

model BillOfMaterials {
  id                  BigInt               @id @default(autoincrement())
  tenantId            BigInt               @map("tenant_id")
  productId           BigInt               @map("product_id")
  outputQty           Decimal?             @map("output_qty") @db.Decimal(12, 3)
  isActive            Boolean              @default(true) @map("is_active")
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bill_of_materials_ibfk_1")
  product             Product              @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bill_of_materials_ibfk_2")
  bomComponents       BomComponent[]
  manufacturingOrders ManufacturingOrder[]

  @@index([productId], map: "product_id")
  @@index([tenantId], map: "tenant_id")
  @@map("bill_of_materials")
}

model BomComponent {
  id                 BigInt          @id @default(autoincrement())
  tenantId           BigInt          @map("tenant_id")
  bomId              BigInt          @map("bom_id")
  componentProductId BigInt          @map("component_product_id")
  qty                Decimal?        @db.Decimal(12, 3)
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bom_components_ibfk_1")
  bom                BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bom_components_ibfk_2")
  componentProduct   Product         @relation(fields: [componentProductId], references: [id], onUpdate: NoAction, map: "bom_components_ibfk_3")

  @@unique([tenantId, bomId, componentProductId], map: "tenant_id")
  @@index([bomId], map: "bom_id")
  @@index([componentProductId], map: "component_product_id")
  @@map("bom_components")
}

model CapitalInvestment {
  id               BigInt    @id @default(autoincrement())
  tenantId         BigInt    @map("tenant_id")
  investorName     String?   @map("investor_name") @db.VarChar(255)
  type             String?   @db.VarChar(20)
  contactNumber    String?   @map("contact_number") @db.VarChar(20)
  email            String?   @db.VarChar(255)
  address          String?   @db.Text
  investmentAmount Decimal?  @map("investment_amount") @db.Decimal(15, 2)
  equityPercent    Decimal?  @map("equity_percent") @db.Decimal(5, 2)
  investmentDate   DateTime? @map("investment_date") @db.Date
  paymentMode      String?   @map("payment_mode") @db.VarChar(50)
  referenceNo      String?   @map("reference_no") @db.VarChar(100)
  notes            String?   @db.Text
  status           String?   @default("Active") @db.VarChar(20)
  createdAt        DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.DateTime(0)
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "capital_investments_ibfk_1")

  @@index([tenantId], map: "tenant_id")
  @@map("capital_investments")
}

model CashTransaction {
  id          BigInt    @id @default(autoincrement())
  tenantId    BigInt    @map("tenant_id")
  date        DateTime? @default(dbgenerated("(curdate())")) @db.Date
  type        String?   @db.VarChar(50)
  amount      Decimal?  @db.Decimal(12, 2)
  refTable    String?   @map("ref_table") @db.VarChar(40)
  refId       BigInt?   @map("ref_id")
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "cash_transactions_ibfk_1")

  @@index([tenantId], map: "tenant_id")
  @@map("cash_transactions")
}

model Category {
  id        BigInt    @id @default(autoincrement())
  tenantId  BigInt    @map("tenant_id")
  name      String?   @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "categories_ibfk_1")
  products  Product[]

  @@unique([tenantId, name], map: "tenant_id")
  @@map("categories")
}

model ChartOfAccount {
  id                   BigInt           @id @default(autoincrement())
  tenantId             BigInt           @map("tenant_id")
  code                 String?          @db.VarChar(20)
  name                 String?          @db.VarChar(150)
  type                 String?          @db.VarChar(20)
  parentId             BigInt?          @map("parent_id")
  tenant               Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chart_of_accounts_ibfk_1")
  parent               ChartOfAccount?  @relation("chart_of_accountsTochart_of_accounts", fields: [parentId], references: [id], onUpdate: NoAction, map: "chart_of_accounts_ibfk_2")
  otherChartOfAccounts ChartOfAccount[] @relation("chart_of_accountsTochart_of_accounts")
  journalLines         JournalLine[]

  @@unique([tenantId, code], map: "tenant_id")
  @@index([parentId], map: "parent_id")
  @@map("chart_of_accounts")
}

model Cheque {
  id            BigInt             @id @default(autoincrement())
  tenantId      BigInt             @map("tenant_id")
  partyId       BigInt?            @map("party_id")
  bankAccountId BigInt?            @map("bank_account_id")
  paymentInId   BigInt?            @map("payment_in_id")
  paymentOutId  BigInt?            @map("payment_out_id")
  partyName     String?            @map("party_name") @db.VarChar(255)
  amount        Decimal?           @db.Decimal(12, 2)
  chequeNo      String?            @map("cheque_no") @db.VarChar(50)
  bank          String?            @db.VarChar(255)
  issueDate     DateTime?          @map("issue_date") @db.Date
  dueDate       DateTime?          @map("due_date") @db.Date
  type          String?            @db.VarChar(5)
  status        String?            @default("pending") @db.VarChar(10)
  createdAt     DateTime           @default(now()) @map("created_at") @db.DateTime(0)
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "cheques_ibfk_1")
  party         Party?             @relation(fields: [partyId], references: [id], onUpdate: NoAction, map: "cheques_ibfk_2")
  bankAccount   BankAccount?       @relation(fields: [bankAccountId], references: [id], onUpdate: NoAction, map: "cheques_ibfk_3")
  paymentIn     PaymentInHistory?  @relation(fields: [paymentInId], references: [id], onUpdate: NoAction, map: "cheques_ibfk_4")
  paymentOut    PaymentOutHistory? @relation(fields: [paymentOutId], references: [id], onUpdate: NoAction, map: "cheques_ibfk_5")

  @@index([bankAccountId], map: "bank_account_id")
  @@index([partyId], map: "party_id")
  @@index([paymentInId], map: "payment_in_id")
  @@index([paymentOutId], map: "payment_out_id")
  @@index([tenantId], map: "tenant_id")
  @@map("cheques")
}

model Department {
  id        BigInt     @id @default(autoincrement())
  tenantId  BigInt     @map("tenant_id")
  name      String?    @db.VarChar(100)
  createdAt DateTime   @default(now()) @map("created_at") @db.DateTime(0)
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "departments_ibfk_1")
  employees Employee[]

  @@unique([tenantId, name], map: "tenant_id")
  @@map("departments")
}

model Designation {
  id        BigInt     @id @default(autoincrement())
  tenantId  BigInt     @map("tenant_id")
  name      String?    @db.VarChar(100)
  createdAt DateTime   @default(now()) @map("created_at") @db.DateTime(0)
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "designations_ibfk_1")
  employees Employee[]

  @@unique([tenantId, name], map: "tenant_id")
  @@map("designations")
}

model EmployeeSalaryStructure {
  id            BigInt          @id @default(autoincrement())
  tenantId      BigInt          @map("tenant_id")
  employeeId    BigInt          @map("employee_id")
  componentId   BigInt          @map("component_id")
  amount        Decimal?        @db.Decimal(12, 2)
  effectiveFrom DateTime?       @map("effective_from") @db.Date
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "employee_salary_structure_ibfk_1")
  employee      Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "employee_salary_structure_ibfk_2")
  component     SalaryComponent @relation(fields: [componentId], references: [id], onUpdate: NoAction, map: "employee_salary_structure_ibfk_3")

  @@index([componentId], map: "component_id")
  @@index([employeeId], map: "employee_id")
  @@index([tenantId], map: "tenant_id")
  @@map("employee_salary_structure")
}

model Employee {
  id                      BigInt                    @id @default(autoincrement())
  tenantId                BigInt                    @map("tenant_id")
  employeeCode            String?                   @map("employee_code") @db.VarChar(50)
  name                    String                    @db.VarChar(150)
  phone                   String?                   @db.VarChar(20)
  email                   String?                   @db.VarChar(150)
  gender                  String?                   @db.VarChar(10)
  dob                     DateTime?                 @db.Date
  designationId           BigInt?                   @map("designation_id")
  departmentId            BigInt?                   @map("department_id")
  dateOfJoining           DateTime?                 @map("date_of_joining") @db.Date
  dateOfExit              DateTime?                 @map("date_of_exit") @db.Date
  exitReason              String?                   @map("exit_reason") @db.Text
  salaryType              String?                   @default("perMonth") @map("salary_type") @db.VarChar(20)
  employeeType            String?                   @default("salaried") @map("employee_type") @db.VarChar(20)
  basicSalary             Decimal?                  @default(0.00) @map("basic_salary") @db.Decimal(12, 2)
  bankAccountNo           String?                   @map("bank_account_no") @db.VarChar(30)
  ifsc                    String?                   @db.VarChar(20)
  pan                     String?                   @db.VarChar(10)
  aadhaar                 String?                   @db.VarChar(255)
  uan                     String?                   @db.VarChar(20)
  esicNo                  String?                   @map("esic_no") @db.VarChar(20)
  emergencyContact        String?                   @map("emergency_contact") @db.VarChar(20)
  photoUrl                String?                   @map("photo_url") @db.Text
  address                 String?                   @db.Text
  notes                   String?                   @db.Text
  isActive                Boolean                   @default(true) @map("is_active")
  createdAt               DateTime                  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt               DateTime                  @default(now()) @map("updated_at") @db.DateTime(0)
  appUsers                AppUser[]
  attendanceRecords       AttendanceRecord[]
  employeeSalaryStructure EmployeeSalaryStructure[]
  tenant                  Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "employees_ibfk_1")
  designation             Designation?              @relation(fields: [designationId], references: [id], onUpdate: NoAction, map: "employees_ibfk_2")
  department              Department?               @relation(fields: [departmentId], references: [id], onUpdate: NoAction, map: "employees_ibfk_3")
  leaveBalances           LeaveBalance[]
  leaveRequests           LeaveRequest[]
  payslips                Payslip[]
  salaryRecords           SalaryRecord[]

  @@unique([tenantId, employeeCode], map: "tenant_id")
  @@index([departmentId], map: "department_id")
  @@index([designationId], map: "designation_id")
  @@index([tenantId, name], map: "idx_employees_tenant_name")
  @@map("employees")
}

model EstimateItem {
  id          BigInt    @id @default(autoincrement())
  tenantId    BigInt    @map("tenant_id")
  estimateId  BigInt    @map("estimate_id")
  productId   BigInt?   @map("product_id")
  name        String?   @db.VarChar(255)
  description String?   @db.Text
  qty         Decimal?  @db.Decimal(12, 3)
  itemCount   Decimal?  @map("item_count") @db.Decimal(12, 3)
  freeQty     Decimal?  @map("free_qty") @db.Decimal(12, 3)
  unit        String?   @db.VarChar(20)
  rate        Decimal?  @db.Decimal(12, 2)
  mrp         Decimal?  @db.Decimal(12, 2)
  gstRate     Decimal?  @map("gst_rate") @db.Decimal(5, 2)
  gstAmount   Decimal?  @map("gst_amount") @db.Decimal(12, 2)
  amount      Decimal?  @db.Decimal(12, 2)
  batchNo     String?   @map("batch_no") @db.VarChar(50)
  expDate     DateTime? @map("exp_date") @db.Date
  mfgDate     DateTime? @map("mfg_date") @db.Date
  size        String?   @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "estimate_items_ibfk_1")
  estimate    Estimate  @relation(fields: [estimateId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "estimate_items_ibfk_2")
  product     Product?  @relation(fields: [productId], references: [id], onUpdate: NoAction, map: "estimate_items_ibfk_3")

  @@index([estimateId], map: "estimate_id")
  @@index([productId], map: "product_id")
  @@index([tenantId], map: "tenant_id")
  @@map("estimate_items")
}

model Estimate {
  id              BigInt         @id @default(autoincrement())
  tenantId        BigInt         @map("tenant_id")
  estimateNo      Int?           @map("estimate_no")
  estimateDate    DateTime?      @default(dbgenerated("(curdate())")) @map("estimate_date") @db.Date
  validTill       DateTime?      @map("valid_till") @db.Date
