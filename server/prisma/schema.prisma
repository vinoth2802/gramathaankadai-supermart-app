generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            Int        @id @default(autoincrement())
  shortName     String     @map("short_name")
  itemCode      String?    @unique @map("item_code")
  category      String     @default("General")
  hsnCode       String?    @map("hsn_code")
  uom           String     @default("PCS")
  purchasePrice Decimal    @default(0) @map("purchase_price") @db.Decimal(12, 2)
  mrp           Decimal    @default(0) @db.Decimal(12, 2)
  salesPrice    Decimal    @default(0) @map("sales_price") @db.Decimal(12, 2)
  gstRate       Decimal    @default(5) @map("gst_rate") @db.Decimal(5, 2)
  stock         Decimal    @default(0) @db.Decimal(12, 3)
  reorderLevel  Decimal    @default(10) @map("reorder_level") @db.Decimal(12, 3)
  expiryDate    DateTime?  @map("expiry_date") @db.Date
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @default(now()) @updatedAt @map("updated_at")
  batch         String?    @db.VarChar(50)
  pcsPerUnit    Int?       @map("pcs_per_unit")
  description   String?
  type          String     @default("Product")
  saleItems     SaleItem[]

  @@index([shortName])
  @@map("products")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("categories")
}

model Party {
  id                Int                 @id @default(autoincrement())
  name              String
  type              String              @default("customer")
  phone             String?
  email             String?
  address           String?
  gstin             String?
  balance           Decimal             @default(0) @db.Decimal(12, 2)
  payable           Decimal             @default(0) @db.Decimal(12, 2)
  lastSale          DateTime?           @map("last_sale") @db.Date
  notes             String?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at")
  partyType         String              @default("B2C") @map("party_type")
  cheques           Cheque[]
  paymentInHistory  PaymentInHistory[]
  paymentOutHistory PaymentOutHistory[]
  purchases         Purchase[]
  sales             Sale[]

  @@map("parties")
}

model Sale {
  id               Int        @id @default(autoincrement())
  invoice          String     @unique
  date             DateTime   @default(now())
  customerName     String     @default("Walk-in Customer") @map("customer_name")
  partyId          Int?       @map("party_id")
  subtotal         Decimal    @default(0) @db.Decimal(12, 2)
  gst              Decimal    @default(0) @db.Decimal(12, 2)
  grandTotal       Decimal    @default(0) @map("grand_total") @db.Decimal(12, 2)
  paymentMode      String?    @map("payment_mode")
  totalReceived    Decimal    @default(0) @map("total_received") @db.Decimal(12, 2)
  changeGiven      Decimal    @default(0) @map("change_given") @db.Decimal(12, 2)
  createdAt        DateTime   @default(now()) @map("created_at")
  status           String     @default("active")
  paymentStatus    String     @default("Paid") @map("payment_status")
  dueDate          DateTime?  @map("due_date") @db.Date
  billingAddress   String?    @map("billing_address")
  shippingAddress  String?    @map("shipping_address")
  phone            String?
  stateOfSupply    String     @default("Tamil Nadu") @map("state_of_supply")
  vehicleNo        String?    @map("vehicle_no")
  deliveryDate     DateTime?  @map("delivery_date") @db.Date
  deliveryLocation String?    @map("delivery_location")
  dispatchLocation String?    @map("dispatch_location")
  notes            String?
  terms            String?
  items            SaleItem[]
  party            Party?     @relation(fields: [partyId], references: [id])

  @@map("sales")
}

model SaleItem {
  id          Int      @id @default(autoincrement())
  saleId      Int      @map("sale_id")
  name        String
  qty         Decimal  @db.Decimal(12, 3)
  rate        Decimal  @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  itemCount   Decimal  @default(0) @map("item_count") @db.Decimal(12, 3)
  batchNo     String?  @map("batch_no")
  expiryDate  String?  @map("exp_date") @db.VarChar(20)
  mfgDate     String?  @map("mfg_date") @db.VarChar(20)
  mrp         Decimal  @default(0) @db.Decimal(12, 2)
  size        String?
  freeQty     Decimal  @default(0) @map("free_qty") @db.Decimal(12, 3)
  unit        String?
  gstRate     Decimal  @default(0) @map("gst_rate") @db.Decimal(5, 2)
  gstAmount   Decimal  @default(0) @map("gst_amount") @db.Decimal(12, 2)
  productId   Int?     @map("product_id")
  product     Product? @relation(fields: [productId], references: [id])
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model Purchase {
  id                  Int            @id @default(autoincrement())
  invoice             String         @unique
  date                DateTime       @default(now())
  partyName           String?        @map("party_name")
  partyId             Int?           @map("party_id")
  grandTotal          Decimal        @default(0) @map("grand_total") @db.Decimal(12, 2)
  paymentMode         String?        @map("payment_mode")
  createdAt           DateTime       @default(now()) @map("created_at")
  supplierInvoiceNo   String?        @map("supplier_invoice_no")
  supplierInvoiceDate DateTime?      @map("supplier_invoice_date") @db.Date
  status              String         @default("active")
  items               PurchaseItem[]
  party               Party?         @relation(fields: [partyId], references: [id])

  @@map("purchases")
}

model PurchaseItem {
  id         Int       @id @default(autoincrement())
  purchaseId Int       @map("purchase_id")
  name       String
  qty        Decimal   @db.Decimal(12, 3)
  price      Decimal   @db.Decimal(12, 2)
  total      Decimal   @db.Decimal(12, 2)
  batchNo    String?   @map("batch_no")
  expiryDate DateTime? @map("expiry_date") @db.Date
  mfgDate    DateTime? @map("mfg_date") @db.Date
  mrp        Decimal   @default(0) @db.Decimal(12, 2)
  unit       String?   @db.VarChar(50)
  gstRate    Decimal   @default(0) @map("gst_rate") @db.Decimal(5, 2)
  gstAmount  Decimal   @default(0) @map("gst_amount") @db.Decimal(12, 2)
  purchase   Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@map("purchase_items")
}

model PaymentMode {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  descr    String?
  isActive Boolean @default(true) @map("is_active")

  @@map("payment_modes")
}

model PaymentInHistory {
  id          Int      @id @default(autoincrement())
  partyId     Int?     @map("party_id")
  partyName   String?  @map("party_name")
  amount      Decimal  @db.Decimal(12, 2)
  paymentMode String?  @map("payment_mode")
  reference   String?
  notes       String?
  date        DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  status      String   @default("Unused")
  party       Party?   @relation(fields: [partyId], references: [id])

  @@map("payment_in_history")
}

model PaymentOutHistory {
  id          Int      @id @default(autoincrement())
  partyId     Int?     @map("party_id")
  partyName   String?  @map("party_name")
  amount      Decimal  @db.Decimal(12, 2)
  paymentMode String?  @map("payment_mode")
  reference   String?
  notes       String?
  date        DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  status      String   @default("Unused") @db.VarChar(20)
  party       Party?   @relation(fields: [partyId], references: [id])

  @@map("payment_out_history")
}

model CashTransaction {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  type        String   @db.VarChar(50)
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("cash_transactions")
}

model BankAccount {
  id        Int      @id @default(autoincrement())
  bankName  String   @map("bank_name")
  accountNo String?  @map("account_no")
  ifsc      String?
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  type      String   @default("Current")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("bank_accounts")
}

model Cheque {
  id        Int       @id @default(autoincrement())
  partyId   Int?      @map("party_id")
  partyName String?   @map("party_name")
  amount    Decimal   @db.Decimal(12, 2)
  chequeNo  String?   @map("cheque_no")
  bank      String?
  issueDate DateTime? @map("issue_date") @db.Date
  dueDate   DateTime? @map("due_date") @db.Date
  type      String
  status    String    @default("pending")
  createdAt DateTime  @default(now()) @map("created_at")
  party     Party?    @relation(fields: [partyId], references: [id])

  @@map("cheques")
}

model LoanAccount {
  id           Int       @id @default(autoincrement())
  name         String
  principal    Decimal?  @db.Decimal(14, 2)
  interestRate Decimal?  @map("interest_rate") @db.Decimal(5, 2)
  emi          Decimal?  @db.Decimal(12, 2)
  startDate    DateTime? @map("start_date") @db.Date
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("loan_accounts")
}

model Settings {
  id            Int      @id @default(1)
  shopName      String   @default("Gramathaankadai SuperMart") @map("shop_name")
  address       String?
  phone         String?
  gstin         String?
  invoicePrefix String   @default("INV") @map("invoice_prefix")
  currency      String   @default("INR")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("settings")
}

model Uom {
  id                     Int             @id @default(autoincrement())
  code                   String          @unique
  descr                  String
  conversionsAsBase      UomConversion[] @relation("BaseUom")
  conversionsAsSecondary UomConversion[] @relation("SecondaryUom")

  @@map("uom_list")
}

model UomConversion {
  id             Int      @id @default(autoincrement())
  baseUomId      Int      @map("base_uom_id")
  factor         Float    @default(1)
  secondaryUomId Int      @map("secondary_uom_id")
  createdAt      DateTime @default(now()) @map("created_at")
  baseUom        Uom      @relation("BaseUom", fields: [baseUomId], references: [id], onDelete: Cascade)
  secondaryUom   Uom      @relation("SecondaryUom", fields: [secondaryUomId], references: [id], onDelete: Cascade)

  @@map("uom_conversions")
}

model AuditLog {
  id       BigInt   @id @default(autoincrement())
  logTime  DateTime @default(now()) @map("log_time")
  userName String?  @map("user_name")
  action   String
  details  Json?

  @@map("audit_log")
}

model flyway_schema_history {
  installed_rank Int      @id(map: "flyway_schema_history_pk")
  version        String?  @db.VarChar(50)
  description    String   @db.VarChar(200)
  type           String   @db.VarChar(20)
  script         String   @db.VarChar(1000)
  checksum       Int?
  installed_by   String   @db.VarChar(100)
  installed_on   DateTime @default(now()) @db.Timestamp(6)
  execution_time Int
  success        Boolean

  @@index([success], map: "flyway_schema_history_s_idx")
}
