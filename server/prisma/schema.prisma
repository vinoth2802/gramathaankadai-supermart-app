generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            Int        @id @default(autoincrement())
  shortName     String     @map("short_name")
  itemCode      String?    @unique @map("item_code")
  category      String     @default("General")
  hsnCode       String?    @map("hsn_code")
  uom           String     @default("PCS")
  purchasePrice Decimal    @default(0) @map("purchase_price") @db.Decimal(12, 2)
  mrp           Decimal    @default(0) @db.Decimal(12, 2)
  salesPrice    Decimal    @default(0) @map("sales_price") @db.Decimal(12, 2)
  gstRate       Decimal    @default(5) @map("gst_rate") @db.Decimal(5, 2)
  stock         Decimal    @default(0) @db.Decimal(12, 3)
  reorderLevel  Decimal    @default(10) @map("reorder_level") @db.Decimal(12, 3)
  minStock      Decimal    @default(0)  @map("min_stock")     @db.Decimal(12, 3)
  expiryDate    DateTime?  @map("expiry_date") @db.Date
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @default(now()) @updatedAt @map("updated_at")
  batch         String?    @db.VarChar(50)
  pcsPerUnit      Int?       @map("pcs_per_unit")
  description     String?
  type            String     @default("Product")
  isBulk          Boolean    @default(false) @map("is_bulk")
  secondaryUnit   String?    @map("secondary_unit") @db.VarChar(20)
  salesPriceTax   String     @default("with") @map("sales_price_tax") @db.VarChar(10)
  wholesalePrice  Decimal    @default(0) @map("wholesale_price") @db.Decimal(12, 2)
  wholesaleQty    Decimal    @default(0) @map("wholesale_qty") @db.Decimal(12, 3)
  purchasePriceTax String    @default("with") @map("purchase_price_tax") @db.VarChar(10)
  atPrice         Decimal    @default(0) @map("at_price") @db.Decimal(12, 2)
  asOfDate        DateTime?  @map("as_of_date") @db.Date
  location        String?    @db.VarChar(100)
  isActive        Boolean    @default(true) @map("is_active")
  saleItems       SaleItem[]

  @@index([shortName])
  @@map("products")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("categories")
}

model Party {
  id                Int                 @id @default(autoincrement())
  name              String
  type              String              @default("customer")
  phone             String?
  email             String?
  address           String?
  gstin             String?
  balance           Decimal             @default(0) @db.Decimal(12, 2)
  payable           Decimal             @default(0) @db.Decimal(12, 2)
  loyaltyPoints     Decimal             @default(0) @map("loyalty_points") @db.Decimal(12, 2)
  lastSale          DateTime?           @map("last_sale") @db.Date
  notes             String?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at")
  partyType         String              @default("B2C") @map("party_type")
  cheques           Cheque[]
  paymentInHistory  PaymentInHistory[]
  paymentOutHistory PaymentOutHistory[]
  purchases         Purchase[]
  sales             Sale[]
  estimates         Estimate[]
  saleReturns       SaleReturn[]
  purchaseReturns   PurchaseReturn[]
  expenses          Expense[]

  @@map("parties")
}

model Sale {
  id               Int        @id @default(autoincrement())
  invoice          String     @unique
  date             DateTime   @default(now())
  customerName     String     @default("Walk-in Customer") @map("customer_name")
  partyId          Int?       @map("party_id")
  subtotal         Decimal    @default(0) @db.Decimal(12, 2)
  discount         Decimal    @default(0) @db.Decimal(12, 2)
  gst              Decimal    @default(0) @db.Decimal(12, 2)
  grandTotal       Decimal    @default(0) @map("grand_total") @db.Decimal(12, 2)
  paymentMode      String?    @map("payment_mode")
  totalReceived    Decimal    @default(0) @map("total_received") @db.Decimal(12, 2)
  changeGiven      Decimal    @default(0) @map("change_given") @db.Decimal(12, 2)
  createdAt        DateTime   @default(now()) @map("created_at")
  status           String     @default("active")
  paymentStatus    String     @default("Paid") @map("payment_status")
  dueDate          DateTime?  @map("due_date") @db.Date
  billingAddress   String?    @map("billing_address")
  shippingAddress  String?    @map("shipping_address")
  phone            String?
  stateOfSupply    String     @default("Tamil Nadu") @map("state_of_supply")
  vehicleNo        String?    @map("vehicle_no")
  deliveryDate     DateTime?  @map("delivery_date") @db.Date
  deliveryLocation String?    @map("delivery_location")
  dispatchLocation String?    @map("dispatch_location")
  notes            String?
  terms            String?
  items            SaleItem[]
  party            Party?     @relation(fields: [partyId], references: [id])

  @@map("sales")
}

model SaleItem {
  id          Int      @id @default(autoincrement())
  saleId      Int      @map("sale_id")
  name        String
  qty         Decimal  @db.Decimal(12, 3)
  rate        Decimal  @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  itemCount   Decimal  @default(0) @map("item_count") @db.Decimal(12, 3)
  batchNo     String?  @map("batch_no")
  expiryDate  String?  @map("exp_date") @db.VarChar(20)
  mfgDate     String?  @map("mfg_date") @db.VarChar(20)
  mrp         Decimal  @default(0) @db.Decimal(12, 2)
  size        String?
  freeQty     Decimal  @default(0) @map("free_qty") @db.Decimal(12, 3)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  unit        String?
  gstRate     Decimal  @default(0) @map("gst_rate") @db.Decimal(5, 2)
  gstAmount   Decimal  @default(0) @map("gst_amount") @db.Decimal(12, 2)
  productId   Int?     @map("product_id")
  product     Product? @relation(fields: [productId], references: [id])
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model Purchase {
  id                  Int            @id @default(autoincrement())
  invoice             String         @unique
  date                DateTime       @default(now())
  partyName           String?        @map("party_name")
  partyId             Int?           @map("party_id")
  subtotal            Decimal        @default(0) @db.Decimal(12, 2)
  discount            Decimal        @default(0) @db.Decimal(12, 2)
  gst                 Decimal        @default(0) @db.Decimal(12, 2)
  grandTotal          Decimal        @default(0) @map("grand_total") @db.Decimal(12, 2)
  totalPaid           Decimal        @default(0) @map("total_paid") @db.Decimal(12, 2)
  paymentStatus       String         @default("Paid") @map("payment_status")
  paymentMode         String?        @map("payment_mode")
  dueDate             DateTime?      @map("due_date") @db.Date
  ewayBillNo          String?        @map("eway_bill_no")
  createdAt           DateTime       @default(now()) @map("created_at")
  supplierInvoiceNo   String?        @map("supplier_invoice_no")
  supplierInvoiceDate DateTime?      @map("supplier_invoice_date") @db.Date
  status              String         @default("active")
  items               PurchaseItem[]
  party               Party?         @relation(fields: [partyId], references: [id])

  @@map("purchases")
}

model PurchaseItem {
  id         Int       @id @default(autoincrement())
  purchaseId Int       @map("purchase_id")
  name       String
  qty        Decimal   @db.Decimal(12, 3)
  price      Decimal   @db.Decimal(12, 2)
  total      Decimal   @db.Decimal(12, 2)
  batchNo    String?   @map("batch_no")
  expiryDate DateTime? @map("expiry_date") @db.Date
  mfgDate    DateTime? @map("mfg_date") @db.Date
  mrp        Decimal   @default(0) @db.Decimal(12, 2)
  discount   Decimal   @default(0) @db.Decimal(12, 2)
  unit       String?   @db.VarChar(50)
  gstRate    Decimal   @default(0) @map("gst_rate") @db.Decimal(5, 2)
  gstAmount  Decimal   @default(0) @map("gst_amount") @db.Decimal(12, 2)
  purchase   Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@map("purchase_items")
}

model PaymentMode {
  id       Int                  @id @default(autoincrement())
  name     String               @unique
  descr    String?
  isActive Boolean              @default(true) @map("is_active")
  settings PaymentTypeSetting?

  @@map("payment_modes")
}

model PaymentTypeSetting {
  id            Int          @id @default(autoincrement())
  paymentModeId Int?         @unique @map("payment_mode_id")
  color         String       @default("blue")
  icon          String       @default("CreditCard")
  description   String?
  displayOrder  Int          @default(0) @map("display_order")
  isDefault     Boolean      @default(false) @map("is_default")
  createdAt     DateTime     @default(now()) @map("created_at")

  paymentMode   PaymentMode? @relation(fields: [paymentModeId], references: [id], onDelete: Cascade)

  @@map("payment_type_settings")
}

model PaymentInHistory {
  id          Int      @id @default(autoincrement())
  partyId     Int?     @map("party_id")
  partyName   String?  @map("party_name")
  amount      Decimal  @db.Decimal(12, 2)
  paymentMode String?  @map("payment_mode")
  reference   String?
  notes       String?
  date        DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  status      String   @default("Unused")
  party       Party?   @relation(fields: [partyId], references: [id])

  @@map("payment_in_history")
}

model PaymentOutHistory {
  id          Int      @id @default(autoincrement())
  partyId     Int?     @map("party_id")
  partyName   String?  @map("party_name")
  amount      Decimal  @db.Decimal(12, 2)
  paymentMode String?  @map("payment_mode")
  reference   String?
  notes       String?
  date        DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  createdAt   DateTime @default(now()) @map("created_at")
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  status      String   @default("Unused") @db.VarChar(20)
  party       Party?   @relation(fields: [partyId], references: [id])

  @@map("payment_out_history")
}

model CashTransaction {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  type        String   @db.VarChar(50)
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("cash_transactions")
}

model BankAccount {
  id        Int      @id @default(autoincrement())
  bankName  String   @map("bank_name")
  accountNo String?  @map("account_no")
  ifsc      String?
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  type      String   @default("Current")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("bank_accounts")
}

model Cheque {
  id        Int       @id @default(autoincrement())
  partyId   Int?      @map("party_id")
  partyName String?   @map("party_name")
  amount    Decimal   @db.Decimal(12, 2)
  chequeNo  String?   @map("cheque_no")
  bank      String?
  issueDate DateTime? @map("issue_date") @db.Date
  dueDate   DateTime? @map("due_date") @db.Date
  type      String
  status    String    @default("pending")
  createdAt DateTime  @default(now()) @map("created_at")
  party     Party?    @relation(fields: [partyId], references: [id])

  @@map("cheques")
}

model LoanAccount {
  id             Int               @id @default(autoincrement())
  name           String
  principal      Decimal?          @db.Decimal(14, 2)
  interestRate   Decimal?          @map("interest_rate") @db.Decimal(5, 2)
  emi            Decimal?          @db.Decimal(12, 2)
  startDate      DateTime?         @map("start_date") @db.Date
  lenderName     String?           @map("lender_name")
  durationMonths Int?              @map("duration_months")
  paymentMode    String?           @map("payment_mode")
  notes          String?
  createdAt      DateTime          @default(now()) @map("created_at")
  transactions   LoanTransaction[]

  @@map("loan_accounts")
}

model LoanTransaction {
  id              Int         @id @default(autoincrement())
  loanId          Int         @map("loan_id")
  type            String
  principal       Decimal     @default(0) @db.Decimal(12, 2)
  interest        Decimal     @default(0) @db.Decimal(12, 2)
  otherCharges    Decimal     @default(0) @map("other_charges") @db.Decimal(12, 2)
  totalAmount     Decimal     @default(0) @map("total_amount") @db.Decimal(12, 2)
  paymentMode     String?     @map("payment_mode")
  referenceNo     String?     @map("reference_no")
  chargeType      String?     @map("charge_type")
  transactionDate DateTime    @map("transaction_date") @db.Date
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")

  loan LoanAccount @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_transactions")
}

model Settings {
  id                    Int      @id @default(1)
  shopName              String   @default("Gramathaankadai SuperMart") @map("shop_name")
  firmName              String?  @map("firm_name")
  address               String?
  pincode               String?
  state                 String?
  phone                 String?
  gstin                 String?
  invoicePrefix         String   @default("INV") @map("invoice_prefix")
  currency              String   @default("INR")
  loyaltyEnabled        Boolean  @default(true)  @map("loyalty_enabled")
  loyaltyPointsPerRupee Decimal  @default(1)     @map("loyalty_points_per_rupee") @db.Decimal(8, 2)
  loyaltyMinPoints      Int      @default(100)   @map("loyalty_min_points")
  loyaltyPointsValue    Decimal  @default(0.10)  @map("loyalty_points_value")    @db.Decimal(8, 2)
  loyaltyExpiryDays     Int      @default(365)   @map("loyalty_expiry_days")
  loyaltyMaxDiscount    Decimal  @default(10)    @map("loyalty_max_discount")    @db.Decimal(5, 2)
  loyaltyAllowPartial   Boolean  @default(true)  @map("loyalty_allow_partial")
  loyaltyShowOnInvoice  Boolean  @default(true)  @map("loyalty_show_on_invoice")

  // Print settings
  printPaperSize           String   @default("A4")                                    @map("print_paper_size")
  printInvoiceTitle        String   @default("Tax Invoice")                           @map("print_invoice_title")
  printCopies              Int      @default(1)                                       @map("print_copies")
  printShowLogo            Boolean  @default(false)                                   @map("print_show_logo")
  printShowAddress         Boolean  @default(true)                                    @map("print_show_address")
  printShowGstin           Boolean  @default(true)                                    @map("print_show_gstin")
  printShowPhone           Boolean  @default(true)                                    @map("print_show_phone")
  printShowCustomerDetails Boolean  @default(true)                                    @map("print_show_customer_details")
  printShowDueDate         Boolean  @default(true)                                    @map("print_show_due_date")
  printShowHsn             Boolean  @default(true)                                    @map("print_show_hsn")
  printShowBatch           Boolean  @default(false)                                   @map("print_show_batch")
  printShowExpiry          Boolean  @default(false)                                   @map("print_show_expiry")
  printShowMrp             Boolean  @default(true)                                    @map("print_show_mrp")
  printShowFreeQty         Boolean  @default(false)                                   @map("print_show_free_qty")
  printShowGstBreakdown    Boolean  @default(true)                                    @map("print_show_gst_breakdown")
  printShowGstSplit        Boolean  @default(false)                                   @map("print_show_gst_split")
  printFooterText          String   @default("Thank you for shopping with us!")       @map("print_footer_text")
  printShowSignature       Boolean  @default(false)                                   @map("print_show_signature")
  printShowTerms           Boolean  @default(false)                                   @map("print_show_terms")
  printTermsText           String   @default("Goods once sold will not be returned.") @map("print_terms_text")
  printShowLoyaltyPoints   Boolean  @default(true)                                    @map("print_show_loyalty_points")

  // Tax settings
  taxMethod            String   @default("exclusive")      @map("tax_method")
  taxDefaultGstRate    Decimal  @default(5)                @map("tax_default_gst_rate")    @db.Decimal(5, 2)
  taxRoundOff          String   @default("nearest_rupee")  @map("tax_round_off")
  taxSupplyType        String   @default("intrastate")     @map("tax_supply_type")
  taxBusinessType      String   @default("regular")        @map("tax_business_type")
  taxCompositionRate   Decimal  @default(1)                @map("tax_composition_rate")    @db.Decimal(5, 2)
  taxEnableTcs         Boolean  @default(false)            @map("tax_enable_tcs")
  taxTcsRate           Decimal  @default(1)                @map("tax_tcs_rate")            @db.Decimal(5, 2)
  taxEnableTds         Boolean  @default(false)            @map("tax_enable_tds")
  taxTdsRate           Decimal  @default(2)                @map("tax_tds_rate")            @db.Decimal(5, 2)
  taxEnableCess        Boolean  @default(false)            @map("tax_enable_cess")
  taxCessRate          Decimal  @default(0)                @map("tax_cess_rate")           @db.Decimal(5, 2)
  taxEnableReverseCharge Boolean @default(false)           @map("tax_enable_reverse_charge")
  taxActiveSlabs       Json     @default("[0,5,12,18,28]") @map("tax_active_slabs")
  taxCustomSlabs       Json     @default("[]")             @map("tax_custom_slabs")

  // Transaction settings — Sales
  txnSalePaymentMode       String   @default("Cash")  @map("txn_sale_payment_mode")
  txnSaleCreditDays        Int      @default(30)       @map("txn_sale_credit_days")
  txnRequireCustomer       Boolean  @default(false)    @map("txn_require_customer")
  txnAllowNegativeStock    Boolean  @default(false)    @map("txn_allow_negative_stock")
  txnDecimalQty            Boolean  @default(true)     @map("txn_decimal_qty")
  txnEnableSaleReturns     Boolean  @default(true)     @map("txn_enable_sale_returns")
  txnSaleReturnDays        Int      @default(7)        @map("txn_sale_return_days")

  // Transaction settings — Purchases
  txnPurchasePaymentMode      String   @default("Cash")  @map("txn_purchase_payment_mode")
  txnPurchaseCreditDays       Int      @default(30)       @map("txn_purchase_credit_days")
  txnAutoUpdatePurchasePrice  Boolean  @default(true)     @map("txn_auto_update_purchase_price")
  txnAutoUpdateMrp            Boolean  @default(false)    @map("txn_auto_update_mrp")
  txnEnablePurchaseReturns    Boolean  @default(true)     @map("txn_enable_purchase_returns")

  // Transaction settings — Invoice Numbering
  txnPurchasePrefix       String   @default("PUR")    @map("txn_purchase_prefix")
  txnEstimatePrefix       String   @default("EST")    @map("txn_estimate_prefix")
  txnInvoiceResetPeriod   String   @default("never")  @map("txn_invoice_reset_period")
  txnInvoicePadding       Int      @default(4)        @map("txn_invoice_padding")

  // Transaction settings — Discount
  txnAllowItemDiscount     Boolean  @default(true)     @map("txn_allow_item_discount")
  txnAllowBillDiscount     Boolean  @default(true)     @map("txn_allow_bill_discount")
  txnMaxDiscountPct        Decimal  @default(100)      @map("txn_max_discount_pct")   @db.Decimal(5, 2)

  // Transaction settings — Estimates & Stock
  txnEnableEstimates       Boolean  @default(true)     @map("txn_enable_estimates")
  txnLowStockWarning       Boolean  @default(true)     @map("txn_low_stock_warning")
  txnBlockBelowMinStock    Boolean  @default(false)    @map("txn_block_below_min_stock")
  txnEnableBarcode         Boolean  @default(true)     @map("txn_enable_barcode")

  // Party settings
  partyDefaultType        String   @default("customer") @map("party_default_type")
  partyDefaultPartyType   String   @default("B2C")      @map("party_default_party_type")
  partyRequirePhone       Boolean  @default(false)       @map("party_require_phone")
  partyRequireGstin       Boolean  @default(false)       @map("party_require_gstin")
  partyEnableCreditLimit  Boolean  @default(false)       @map("party_enable_credit_limit")
  partyDefaultCreditLimit Decimal  @default(0)           @map("party_default_credit_limit") @db.Decimal(12, 2)
  partyDuplicateCheck     Boolean  @default(true)        @map("party_duplicate_check")
  partyShowBalance        Boolean  @default(true)        @map("party_show_balance")
  partyAutoWhatsapp       Boolean  @default(false)       @map("party_auto_whatsapp")

  // Item settings
  itemDefaultUom          String   @default("PCS")   @map("item_default_uom")
  itemEnableBatch         Boolean  @default(false)    @map("item_enable_batch")
  itemEnableExpiry        Boolean  @default(false)    @map("item_enable_expiry")
  itemEnableMrp           Boolean  @default(true)     @map("item_enable_mrp")
  itemEnableHsn           Boolean  @default(true)     @map("item_enable_hsn")
  itemEnableLocation      Boolean  @default(false)    @map("item_enable_location")
  itemDefaultReorderLevel Decimal  @default(10)       @map("item_default_reorder_level") @db.Decimal(12, 3)
  itemPriceDecimals       Int      @default(2)        @map("item_price_decimals")
  itemQtyDecimals         Int      @default(3)        @map("item_qty_decimals")
  itemEnableWholesale     Boolean  @default(false)    @map("item_enable_wholesale")
  itemBarcodeType         String   @default("EAN13")  @map("item_barcode_type")
  itemNegativeStockAlert  Boolean  @default(true)     @map("item_negative_stock_alert")

  // Unit settings
  unitDefaultCode         String   @default("PCS")   @map("unit_default_code")
  unitEnableConversion    Boolean  @default(false)    @map("unit_enable_conversion")
  unitEnableSecondary     Boolean  @default(false)    @map("unit_enable_secondary")

  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("settings")
}

model Uom {
  id                     Int             @id @default(autoincrement())
  code                   String          @unique
  descr                  String
  conversionsAsBase      UomConversion[] @relation("BaseUom")
  conversionsAsSecondary UomConversion[] @relation("SecondaryUom")

  @@map("uom_list")
}

model UomConversion {
  id             Int      @id @default(autoincrement())
  baseUomId      Int      @map("base_uom_id")
  factor         Float    @default(1)
  secondaryUomId Int      @map("secondary_uom_id")
  createdAt      DateTime @default(now()) @map("created_at")
  baseUom        Uom      @relation("BaseUom", fields: [baseUomId], references: [id], onDelete: Cascade)
  secondaryUom   Uom      @relation("SecondaryUom", fields: [secondaryUomId], references: [id], onDelete: Cascade)

  @@map("uom_conversions")
}

model AuditLog {
  id       BigInt   @id @default(autoincrement())
  logTime  DateTime @default(now()) @map("log_time")
  userName String?  @map("user_name")
  action   String
  details  Json?

  @@map("audit_log")
}

model flyway_schema_history {
  installed_rank Int      @id(map: "flyway_schema_history_pk")
  version        String?  @db.VarChar(50)
  description    String   @db.VarChar(200)
  type           String   @db.VarChar(20)
  script         String   @db.VarChar(1000)
  checksum       Int?
  installed_by   String   @db.VarChar(100)
  installed_on   DateTime @default(now()) @db.Timestamp(6)
  execution_time Int
  success        Boolean

  @@index([success], map: "flyway_schema_history_s_idx")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Estimate {
  id             Int            @id @default(autoincrement())
  estimateNo     Int            @map("estimate_no")
  estimateDate   DateTime       @default(now()) @map("estimate_date") @db.Date
  validTill      DateTime?      @map("valid_till") @db.Date
  partyId        Int?           @map("party_id")
  customerName   String         @default("Walk-in Customer") @map("customer_name")
  phone          String?
  billingAddress String?        @map("billing_address")
  stateOfSupply  String         @default("Tamil Nadu") @map("state_of_supply")
  subtotal       Decimal        @default(0) @db.Decimal(12, 2)
  gst            Decimal        @default(0) @db.Decimal(12, 2)
  grandTotal     Decimal        @default(0) @map("grand_total") @db.Decimal(12, 2)
  adjustment     Decimal        @default(0) @db.Decimal(12, 2)
  status         String         @default("Open")
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @default(now()) @updatedAt @map("updated_at")
  items          EstimateItem[]
  party          Party?         @relation(fields: [partyId], references: [id])

  @@map("estimates")
}

model EstimateItem {
  id          Int      @id @default(autoincrement())
  estimateId  Int      @map("estimate_id")
  productId   Int?     @map("product_id")
  name        String
  description String?
  itemCount   Decimal  @default(0) @map("item_count") @db.Decimal(12, 3)
  batchNo     String?  @map("batch_no")
  expiryDate  String?  @map("exp_date") @db.VarChar(20)
  mfgDate     String?  @map("mfg_date") @db.VarChar(20)
  mrp         Decimal  @default(0) @db.Decimal(12, 2)
  size        String?
  qty         Decimal  @default(0) @db.Decimal(12, 3)
  freeQty     Decimal  @default(0) @map("free_qty") @db.Decimal(12, 3)
  unit        String?
  rate        Decimal  @default(0) @db.Decimal(12, 2)
  gstRate     Decimal  @default(0) @map("gst_rate") @db.Decimal(5, 2)
  gstAmount   Decimal  @default(0) @map("gst_amount") @db.Decimal(12, 2)
  amount      Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

