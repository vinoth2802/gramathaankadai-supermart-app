  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "stock_transfers_ibfk_1")
  fromLocation       TenantLocation      @relation("stock_transfers_from_location_idTotenant_locations", fields: [fromLocationId], references: [id], onUpdate: NoAction, map: "stock_transfers_ibfk_2")
  toLocation         TenantLocation      @relation("stock_transfers_to_location_idTotenant_locations", fields: [toLocationId], references: [id], onUpdate: NoAction, map: "stock_transfers_ibfk_3")

