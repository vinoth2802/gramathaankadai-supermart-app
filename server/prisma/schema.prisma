}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model AppUser {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(150)
  phone        String?   @db.VarChar(20)
  passwordHash String    @map("password_hash")
  roleId       Int       @map("role_id")
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  role         AppRole   @relation(fields: [roleId], references: [id])

  @@map("app_users")
}

model AppRole {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  users           AppUser[]
  rolePermissions AppRolePermission[]

  @@map("app_roles")
}

model Designation {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("designations")
}

model Employee {
  id                Int                  @id @default(autoincrement())
  employeeCode      String?              @unique @map("employee_code") @db.VarChar(50)
  name              String               @db.VarChar(150)
  phone             String?              @db.VarChar(20)
  email             String?              @db.VarChar(150)
  designation       String?              @db.VarChar(100)
  department        String?              @db.VarChar(100)
  dateOfJoining     DateTime?            @map("date_of_joining") @db.Date
  basicSalary       Decimal              @default(0) @map("basic_salary") @db.Decimal(12, 2)
  salaryType        String               @default("perMonth") @map("salary_type") @db.VarChar(20)
  address           String?
  notes             String?
  isActive          Boolean              @default(true) @map("is_active")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @default(now()) @updatedAt @map("updated_at")
  salaryRecords     SalaryRecord[]
  attendanceRecords AttendanceRecord[]

  @@index([name])
  @@map("employees")
}

model AttendanceRecord {
  id         Int       @id @default(autoincrement())
  employeeId Int       @map("employee_id")
  date       DateTime  @db.Date
  status     String    @db.VarChar(20)
  note       String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendance_records")
}

model SalaryRecord {
  id             Int       @id @default(autoincrement())
  employeeId     Int       @map("employee_id")
  type           String    @db.VarChar(20)
  amount         Decimal   @db.Decimal(12, 2)
  previousSalary Decimal?  @map("previous_salary") @db.Decimal(12, 2)
  effectiveDate  DateTime  @map("effective_date") @db.Date
  paidDate       DateTime? @map("paid_date") @db.Date
  payStatus      String    @default("unpaid") @map("pay_status") @db.VarChar(20)
  description    String?
  createdAt      DateTime  @default(now()) @map("created_at")
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("salary_records")
}

model AppPermission {
  id          Int    @id @default(autoincrement())
  module      String @db.VarChar(50)
  action      String @db.VarChar(50)
  description String?

  rolePermissions AppRolePermission[]

  @@unique([module, action])
  @@map("app_permissions")
}

model AppRolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       AppRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission AppPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("app_role_permissions")
}

model SaleReturn {
  id               Int              @id @default(autoincrement())
  creditNoteNo     String           @unique @map("credit_note_no")
  date             DateTime         @default(now()) @db.Date
  partyId          Int?             @map("party_id")
  partyName        String           @default("Walk-in Customer") @map("party_name")
  referenceInvoice String?          @map("reference_invoice")
  type             String           @default("Credit Note")
  subtotal         Decimal          @default(0) @db.Decimal(12, 2)
  gst              Decimal          @default(0) @db.Decimal(12, 2)
  grandTotal       Decimal          @default(0) @map("grand_total") @db.Decimal(12, 2)
  paymentMode      String?          @default("Cash") @map("payment_mode")
  totalReceived    Decimal          @default(0) @map("total_received") @db.Decimal(12, 2)
  dueDate          DateTime?        @map("due_date") @db.Date
  paymentStatus    String           @default("Unpaid") @map("payment_status")
  notes            String?
  status           String           @default("active")
  createdAt        DateTime         @default(now()) @map("created_at")
  party            Party?           @relation(fields: [partyId], references: [id])
