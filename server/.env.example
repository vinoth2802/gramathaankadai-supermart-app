# ── Database ───────────────────────────────────────────────────────────────

# Option A: Docker MySQL (docker compose up -d mysql)
DATABASE_URL=mysql://root:root@localhost:3307/gramathaankadai_db

# Option B: Local MySQL installed on machine (change password and port as needed)
# DATABASE_URL=mysql://root:YOUR_PASSWORD@localhost:3306/gramathaankadai_db

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001

# ── Production (Railway) ───────────────────────────────────────────────────
# DATABASE_URL=mysql://user:password@host:port/database   ← from Railway MySQL plugin
# PORT is injected automatically by Railway — do not set manually
