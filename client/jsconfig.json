{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*":          ["src/*"],
      "@api/*":       ["src/api/*"],
      "@components/*":["src/components/*"],
      "@utils/*":     ["src/utils/*"],
      "@features/*":  ["src/features/*"],
      "@lib/*":       ["src/lib/*"],
      "@constants":   ["src/constants/index.js"],
      "@schemas/*":   ["src/schemas/*"]
    }
  },
  "include": ["src"]
}
