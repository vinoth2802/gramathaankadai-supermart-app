{
  "name": "gramathankadai-supermart-app",
  "version": "1.0.0",
  "description": "SuperMart - Gramathaankadai POS & Management App",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite --open\"",
    "predev": "node -e \"const fs=require('fs');if(!fs.existsSync('server/db.json'))fs.copyFileSync('server/db.sample.json','server/db.json')\"",
    "server": "json-server --watch server/db.json --routes server/routes.json --middlewares server/middleware.js --port 3000",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "json-server": "^0.17.4",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "vite": "^5.0.0"
  }
}
